# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ecom?retryWrites=true&w=majority

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cashfree Payment Configuration
# Get these from: https://dashboard.cashfree.com/merchants
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
CASHFREE_API_URL=https://sandbox.cashfree.com/pg

# Frontend and Webhook URLs
FRONTEND_URL=http://localhost:3001
WEBHOOK_URL=http://localhost:3002/api/payment/webhook

# Server Configuration
PORT=3002
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
